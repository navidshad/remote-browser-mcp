# Copy this to .env and fill in values before running docker-compose

# Anthropic API key (required by the agent)
ANTHROPIC_API_KEY=sk-ant-...

# Public tunnel URLs (set these after running `make start-local` and noting
# the cloudflared output).
# In M1 (local, no tunnel): use localhost URLs directly
PLAYWRIGHT_URL=http://localhost:3000
DAEMON_URL=http://localhost:3001/mcp

# Tunnel URLs for M2 (Docker mock VM or real AWS VM):
# PLAYWRIGHT_URL=https://xxx.trycloudflare.com
# DAEMON_URL=https://yyy.trycloudflare.com/mcp

# Optional overrides
# CDP_PORT=9222
# PLAYWRIGHT_PORT=3000
# DAEMON_PORT=3001
# MODEL=claude-opus-4-8
