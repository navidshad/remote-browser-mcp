# Copy this to .env and fill in values before running docker-compose

# ── LLM provider ──────────────────────────────────────────────────────────────
# Which LLM drives the agent: gemini (default) or anthropic.
LLM_PROVIDER=gemini

# Gemini key (required when LLM_PROVIDER=gemini). GOOGLE_API_KEY also works.
GEMINI_API_KEY=...

# Anthropic key (only needed when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model. Defaults per provider:
#   gemini    -> gemini-2.5-flash   (alts: gemini-3.5-flash, gemini-2.5-pro)
#   anthropic -> claude-opus-4-8
# MODEL=gemini-2.5-flash

# Public tunnel URLs (set these after running `make start-local` and noting
# the cloudflared output).
# In M1 (local, no tunnel): use localhost URLs directly
PLAYWRIGHT_URL=http://localhost:3000
DAEMON_URL=http://localhost:3001/mcp

# Tunnel URLs for M2 (Docker mock VM or real AWS VM):
# PLAYWRIGHT_URL=https://xxx.trycloudflare.com
# DAEMON_URL=https://yyy.trycloudflare.com/mcp

# Optional overrides
# CDP_PORT=9222
# PLAYWRIGHT_PORT=3000
# DAEMON_PORT=3001
