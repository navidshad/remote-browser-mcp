# Copy this to .env and fill in values.

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ NEW PATH — bridge-server + custom MV3 extension (see README "Bridge")      ║
# ╠══════════════════════════════════════════════════════════════════════════╣
# The extension on the Mac dials OUT to the bridge on the VM and authenticates
# with this shared token. Set the SAME value here (VM) and in the extension
# popup (Mac). Generate one with: openssl rand -hex 32
BRIDGE_ACCESS_TOKEN=

# Bridge ports on the VM. MCP face is localhost-only (the VM's Claude Code /
# packages/agent connect here). WS face is exposed publicly by cloudflared.
MCP_PORT=3000
WS_PORT=3002

# packages/agent (the standalone test agent) points BOTH of these at the bridge
# MCP face — one endpoint serves check_local_status AND the browser_* tools.
PLAYWRIGHT_URL=http://localhost:3000
DAEMON_URL=http://localhost:3000/mcp

# ── LLM provider (only needed for the standalone packages/agent) ──────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=...
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL=gemini-2.5-flash   # gemini default; anthropic default -> claude-opus-4-8

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ RETIRED PATH — Playwright MCP over a Mac-side tunnel (kept for reference)   ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# PLAYWRIGHT_URL=https://browser.subturtle.app
# DAEMON_URL=https://browser-daemon.subturtle.app/mcp
# CDP_PORT=9222
# PLAYWRIGHT_PORT=3000
# DAEMON_PORT=3001
