{
  "name": "@remote-browser-mcp/agent",
  "version": "0.1.0",
  "description": "Terminal agent that drives the local browser through the tunnel",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "remote-browser-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "smoke": "tsx src/smoke-test.ts",
    "live": "tsx src/live-test.ts",
    "task": "tsx src/task-report.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@google/genai": "^2.8.0",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
