FROM node:22-alpine AS builder

WORKDIR /build

# Copy workspace root and agent package manifests first for layer caching
COPY package.json ./
COPY packages/agent/package.json ./packages/agent/

# npm workspaces hoists deps to the root node_modules
RUN npm install --workspace=packages/agent

COPY packages/agent ./packages/agent/
RUN npm run build --workspace=packages/agent

# ── Runtime image ─────────────────────────────────────────────────────────────
FROM node:22-alpine AS runtime

WORKDIR /app

# Hoisted dependencies live at the workspace root
COPY --from=builder /build/node_modules ./node_modules
COPY --from=builder /build/packages/agent/dist ./dist

# Config is supplied at run time (docker-compose env / -e flags), not baked in.
# LLM_PROVIDER defaults to gemini in the app; MODEL defaults per provider.
CMD ["node", "dist/index.js"]
